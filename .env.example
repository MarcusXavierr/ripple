# WebSocket signaling server URL (no trailing slash)
VITE_WS_URL=wss://localhost:9999/ws
VITE_RIPPLE_EXTENSION_ID="aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
# Contact email shown on the Privacy page (mailto target and inline mention)
VITE_CONTACT_EMAIL=
# Waitlist endpoint (POST { email: string }). Required in production.
# In dev, falls back to http://localhost:9999/waitlist.
VITE_WAITLIST_URL=
